<?xml version="1.0" encoding="utf-8"?>
<nav xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    app:startDestination="@id/onboardFragment">

    <fragment
        android:id="@+id/onboardFragment"
        android:name="com.triplet.OnboardFragment"
        android:label="OnboardFragment"
        tools:layout="@layout/onboard_fragment">
        <action
            android:id="@+id/action_onboardFragment_to_signUpFragment"
            app:destination="@id/signUpFragment" />
        <action
            android:id="@+id/action_onboardFragment_to_signInFragment"
            app:destination="@id/signInFragment" />
    </fragment>

    <fragment
        android:id="@+id/signUpFragment"
        android:name="com.triplet.SignUpFragment"
        android:label="SignUpFragment"
        tools:layout="@layout/sign_up_fragment">
        <action
            android:id="@+id/action_signUpFragment_to_signInFragment"
            app:destination="@id/signInFragment">
            <!-- Указываем, что при навигации можно передать аргумент user -->
            <argument
                android:name="user"
                app:argType="com.triplet.models.User" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/signInFragment"
        android:name="com.triplet.SignInFragment"
        android:label="SignInFragment"
        tools:layout="@layout/sign_in_fragment">
        <argument
            android:name="user"
            app:argType="com.triplet.models.User" />
        <action
            android:id="@+id/action_signInFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_signInFragment_to_onboardFragment"
            app:destination="@id/onboardFragment" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.triplet.HomeFragment"
        android:label="HomeFragment"
        tools:layout="@layout/home_fragment" />
</nav>
